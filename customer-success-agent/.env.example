# =============================================================================
# CS Agent — Environment Configuration
# =============================================================================

# Required: LLM API (pick one)
# Primary: Anthropic direct (auto-detected via sk-ant- prefix)
ANTHROPIC_API_KEY=your_anthropic_key_here
# Fallback: OpenRouter (used if ANTHROPIC_API_KEY is not set, or if FORCE_OPENROUTER=true)
# OPENROUTER_API_KEY=your_openrouter_key_here

EXA_API_KEY=your_exa_key_here

# Optional: Model override (defaults to claude-sonnet-4-6)
# MODEL=claude-sonnet-4-6
# MODEL=anthropic/claude-sonnet-4.6  # via OpenRouter
# API_BASE=https://openrouter.ai/api/v1  # fallback only

# Optional: Local model (e.g., LM Studio)
# API_BASE=http://localhost:1234/v1
# MODEL=local-model-name

# Optional: Force OpenRouter path even with Anthropic key (for testing)
# FORCE_OPENROUTER=true

# MCP Integrations (optional — see docs/mcp-setup.md)
MCP_GMAIL_ENABLED=false
MCP_SUPABASE_ENABLED=false
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# Benchmark judge model (should differ from agent model to reduce bias)
# JUDGE_MODEL=meta-llama/llama-3.3-70b-instruct:free
